# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App's own API keys (for free tier - 5 analyses/month for registered users)
OPENAI_API_KEY=sk-...
GOOGLE_KG_API_KEY=AIza...
GEMINI_API_KEY=AIza...

# Encryption key for saved user API keys (generate with: openssl rand -base64 32)
KEY_ENCRYPTION_KEY=your-base64-encoded-32-byte-key
